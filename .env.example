# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...

# ── Optional (defaults shown) ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/ednex.db
STORAGE_DIR=./data/storage
CHROMA_DIR=./data/chroma
LOG_LEVEL=INFO
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_TIMEOUT_SECONDS=12
OPENAI_TTS_MAX_RETRIES=0

# ── Unitree G1 Robot (optional) ────────────────────────────────────────────────
# Set ROBOT_ENABLED=true when the G1 is connected via Ethernet.
# Find your NIC name with: ip link show
# PC mode (default): ROBOT_ENABLED=false — audio plays through the browser.
# Robot mode:        ROBOT_ENABLED=true  — audio streams to the G1 speaker.
ROBOT_ENABLED=false
ROBOT_NETWORK_INTERFACE=eth0
ROBOT_VOLUME=100
ROBOT_PCM_GAIN=2.0
